# ── App ─────────────────────────────────────────────────────
OP_PASSWORD=avery123
PORT=3001

# ── Email notifications (nodemailer / Gmail) ─────────────────
# Set NOTIFY_EMAIL + SMTP_USER + SMTP_PASS to enable email alerts.
# For Gmail, generate an App Password at https://myaccount.google.com/apppasswords
NOTIFY_EMAIL=you@example.com
SMTP_USER=sender@gmail.com
SMTP_PASS=your-app-password-here
# SMTP_HOST=smtp.gmail.com   # optional — defaults to smtp.gmail.com
# SMTP_PORT=587               # optional — 587 (STARTTLS) or 465 (SSL)

# ── Webhook notifications ────────────────────────────────────
# POST to any URL on change. Works with Discord webhooks, ntfy.sh, etc.
# Discord:  https://discord.com/api/webhooks/<id>/<token>
# ntfy.sh:  https://ntfy.sh/your-topic  (set Content-Type: application/json)
NOTIFY_WEBHOOK=
