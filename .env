# ── Notifications (optional) ─────────────────────────────────
# Fill in any combination below — unused options are safely ignored.

# Email: set NOTIFY_EMAIL to receive updates at that address.
# SMTP_USER / SMTP_PASS are your sending credentials.
# Gmail: use an App Password from https://myaccount.google.com/apppasswords
#NOTIFY_EMAIL=you@example.com
#SMTP_USER=your-gmail@gmail.com
#SMTP_PASS=xxxx-xxxx-xxxx-xxxx
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587

# Webhook: POST JSON to any URL on each update.
